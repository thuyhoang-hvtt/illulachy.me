---
import '../styles/global.css'
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page not found — Writing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif:wght@400;600&family=Space+Grotesk:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-surface-default text-text-primary font-body antialiased">
    <main class="min-h-screen flex flex-col items-center justify-center px-8">
      <h1 class="font-heading text-4xl font-semibold text-text-primary leading-tight text-center mb-6">
        This page doesn't exist. The writing does.
      </h1>
      <a href="/"
         class="text-interactive-default hover:text-interactive-hover text-base transition-colors duration-150 hover:underline">
        &larr; Back to writing
      </a>
    </main>
  </body>
</html>
