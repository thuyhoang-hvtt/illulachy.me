---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PostCard from '../../components/PostCard.astro'
import { calcReadingTime } from '../../lib/reading-time'
import { slugify } from '../../lib/slugify'

export async function getStaticPaths() {
  const postModules = import.meta.glob(
    '../../../../../packages/content/content/posts/**/*.md',
    { eager: true }
  )

  interface PostFrontmatter {
    title: string
    date: string
    excerpt: string
    tags: string[]
    category: string
  }

  const allPosts = Object.entries(postModules)
    .map(([path, mod]: [string, any]) => ({
      slug: path.split('/').pop()!.replace('.md', ''),
      frontmatter: mod.frontmatter as PostFrontmatter,
      readingTime: calcReadingTime(mod.rawContent?.() ?? ''),
    }))
    .filter(p => p.frontmatter?.title)

  const allTags = [...new Set(
    allPosts.flatMap(p => p.frontmatter.tags ?? [])
  )]

  return allTags.map(tag => ({
    params: { tag: slugify(tag) },
    props: {
      tagName: tag,
      posts: allPosts
        .filter(p =>
          (p.frontmatter.tags ?? [])
            .map((t: string) => slugify(t))
            .includes(slugify(tag))
        )
        .sort((a, b) =>
          new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
        ),
    },
  }))
}

const { tagName, posts } = Astro.props
---

<BaseLayout title={`#${tagName} — Writing`}>
  <main class="max-w-[680px] mx-auto px-8 max-sm:px-4 py-16">
    <h1 class="font-heading text-4xl font-semibold text-text-primary leading-tight tracking-tight mb-12">
      #{tagName}
    </h1>

    {posts.length === 0 ? (
      <div class="text-center py-16">
        <p class="text-text-secondary mb-4">No posts in this tag yet.</p>
        <a href="/" class="text-interactive-default hover:text-interactive-hover text-sm transition-colors duration-150">
          &larr; Back to all posts
        </a>
      </div>
    ) : (
      <div class="flex flex-col gap-8">
        {posts.map(post => <PostCard post={post} />)}
      </div>
    )}
  </main>
</BaseLayout>
